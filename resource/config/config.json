{
  "auto_indent": true,
  "auto_pair": true,
  "tab_space": true,
  "tab_stop": 4,
  "wrap": false,

  "end_of_buffer_mark": false,
  "line_number": 1,
  "trailing_white": true,

  "basic_word_completion": true,
  "cmp_menu_max_height": 15,
  "cmp_menu_max_width": 40,
  "colorscheme": "default",
  "highlight_on_search": true,
  "input_idle_timeout": 100,
  "logverbose": false,
  "max_edit_history": 100,
  "max_jump_history": 100,
  "scroll_rows": 3,
  "truecolor": true,
  "vim": false,

  "cursor_start_holding_interval": 500,

  "makefile": {
    "tab_space": false
  },
  "markdown": {
    "wrap": true
  },
  "txt": {
    "wrap": true
  }
}
